INDEXGUARD_RUNTIME_DIR=data/runtime
INDEXGUARD_HOST=127.0.0.1
INDEXGUARD_PORT=8000

# Inbound credentials used by B and C when calling the A REST API.
INDEXGUARD_B_TOKEN=replace-with-inbound-b-token
INDEXGUARD_OPERATOR_TOKEN=replace-with-c-operator-token

# Optional outbound HTTP B analyzer. Without URL, /dispatch fails closed (503).
INDEXGUARD_B_ANALYZE_URL=http://127.0.0.1:9000/analyze
INDEXGUARD_B_OUTBOUND_TOKEN=replace-with-outbound-b-token
INDEXGUARD_B_TIMEOUT_SECONDS=15

# OpenAI-compatible model service for Git diff summaries and future agent analysis.
# A key is intentionally optional because the configured local/private endpoint accepts none.
INDEXGUARD_OPENAI_BASE_URL=http://100.102.81.122:8000/v1
INDEXGUARD_OPENAI_API_KEY=
# Leave empty to choose the first model returned by GET /v1/models.
INDEXGUARD_OPENAI_MODEL=
INDEXGUARD_OPENAI_TIMEOUT_SECONDS=30
# Opt in only when the compatible endpoint is intentionally used as B risk analysis.
# An ALLOW result still waits for an explicit C operator APPROVE command.
INDEXGUARD_OPENAI_RISK_ENABLED=false

# Optional HWPX-to-PDF renderer used before OpenDataLoader layout normalization.
# Defaults to soffice/libreoffice on PATH and common Windows installation paths.
INDEXGUARD_LIBREOFFICE_PATH=
# Optional Java path for long-running Windows services whose PATH predates Java installation.
INDEXGUARD_JAVA_PATH=

# B-only Streamable HTTP MCP stays on 127.0.0.1; stdio ignores this port.
INDEXGUARD_MCP_PORT=8001
